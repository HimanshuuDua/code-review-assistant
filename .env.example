# HuggingFace
HF_TOKEN=
BASE_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3
FINETUNED_MODEL_ID=HimanshuuDua/code-review-mistral-lora
CODEREVIEWER_MODEL_ID=microsoft/codereviewer

# Inference: hybrid | demo | huggingface | local
INFERENCE_MODE=hybrid
INFERENCE_FALLBACK_DEMO=true

# Storage
DATABASE_URL=sqlite+aiosqlite:///./data/reviews.db
STORAGE_ENABLED=true
ADMIN_API_KEY=change-me-in-production

# App
APP_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_HOST=0.0.0.0
API_PORT=8000

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
