# HuggingFace token (required for gated models & pushing adapters)
HF_TOKEN=your_huggingface_token_here

# Base model (Mistral 7B Instruct)
BASE_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3

# Your fine-tuned LoRA adapter on HuggingFace Hub
FINETUNED_MODEL_ID=your-username/code-review-mistral-lora

# Inference mode: "local" | "huggingface" | "demo"
INFERENCE_MODE=demo

# HuggingFace Inference API (when INFERENCE_MODE=huggingface)
HF_INFERENCE_API_URL=https://api-inference.huggingface.co/models

# Backend
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
